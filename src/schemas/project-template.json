{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProjectTemplate",
  "definitions": {
    "ProjectTemplate": {
      "type": "object",
      "required": ["title", "plan"],
      "properties": {
        "title": { "type": "string" },
        "wizardPages": {
          "type": "array",
          "items": { "$ref": "#/definitions/WizardPage" }
        },
        "plan": { "$ref": "#/definitions/TemplateProjectPlan" }
      }
    },
    "WizardPage": {
      "type": "object",
      "required": ["fields"],
      "properties": {
        "fields": { "$ref": "#/definitions/WizardField" }
      }
    },
    "BaseWizardField": {
      "type": "object",
      "required": ["name", "label", "type"],
      "properties": {
        "name": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" }
      }
    },
    "WizardTextAreaField": {
      "allOf": [{ "$ref": "#/definitions/BaseWizardField" }],
      "properties": {
        "type": { "const": "textarea" }
      },
      "required": ["type"]
    },
    "WizardInputField": {
      "allOf": [{ "$ref": "#/definitions/BaseWizardField" }],
      "properties": {
        "type": { "const": "input" }
      },
      "required": ["type"]
    },
    "WizardField": {
      "oneOf": [{ "$ref": "#/definitions/WizardInputField" }, { "$ref": "#/definitions/WizardTextAreaField" }]
    },
    "TemplateProjectPlan": {
      "type": "object",
      "required": ["nodes"],
      "properties": {
        "nodes": { "$ref": "#/definitions/TemplateProjectNode" }
      }
    },
    "TemplateProjectNode": {
      "type": "object",
      "required": ["id", "title", "type"],
      "properties": {
        "id": { "type": "number" },
        "title": { "type": "string" },
        "type": { "$ref": "plan-node-types.json#" },
        "aiUserInstructions": { "type": "array", "items": { "type": "string" } },
        "content": { "type": "array", "items": { "type": "string" } },
        "children": { "$ref": "#/definitions/TemplateProjectNode" },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/definitions/TemplateProjectNodeInput" }
        }
      }
    },
    "TemplateProjectNodeInput": {
      "type": "object",
      "required": ["sourceNodeId", "type"],
      "properties": {
        "sourceNodeId": { "type": "number" },
        "type": { "$ref": "plan-edge-types.json#" }
      }
    }
  }
}
