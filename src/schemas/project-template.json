{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProjectTemplate",
  "type": "object",
  "required": ["label", "description", "plan"],
  "properties": {
    "$schema": { "type": "string" },
    "label": { "type": "string" },
    "description": { "type": "string" },
    "wizardPages": {
      "type": "array",
      "items": { "$ref": "#/definitions/WizardPage" }
    },
    "lore": { "$ref": "#/definitions/TemplateProjectLore" },
    "plan": { "$ref": "#/definitions/TemplateProjectPlan" }
  },
  "additionalProperties": false,
  "definitions": {
    "WizardPage": {
      "type": "object",
      "required": ["fields"],
      "properties": {
        "fields": { "type": "array", "items": { "$ref": "#/definitions/WizardField" } }
      },
      "additionalProperties": false
    },
    "BaseWizardField": {
      "type": "object",
      "required": ["name", "label", "type"],
      "properties": {
        "name": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" }
      }
    },
    "WizardTextAreaField": {
      "allOf": [{ "$ref": "#/definitions/BaseWizardField" }],
      "properties": {
        "type": { "const": "textarea" },
        "placeholder": { "type": "string" }
      },
      "required": ["type"],
      "unevaluatedProperties": false
    },
    "WizardInputField": {
      "allOf": [{ "$ref": "#/definitions/BaseWizardField" }],
      "properties": {
        "type": { "const": "input" },
        "placeholder": { "type": "string" }
      },
      "required": ["type"],
      "unevaluatedProperties": false
    },
    "WizardField": {
      "oneOf": [{ "$ref": "#/definitions/WizardInputField" }, { "$ref": "#/definitions/WizardTextAreaField" }]
    },
    "TemplateProjectLore": {
      "type": "object",
      "required": ["nodes"],
      "properties": {
        "nodes": { "type": "array", "items": { "$ref": "#/definitions/TemplateProjectLoreNode" } }
      },
      "additionalProperties": false
    },
    "TemplateProjectLoreNode": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "number" },
        "title": { "type": "string" },
        "content": { "type": "array", "items": { "type": "string" } },
        "children": { "type": "array", "items": { "$ref": "#/definitions/TemplateProjectLoreNode" } }
      },
      "additionalProperties": false
    },
    "TemplateProjectPlan": {
      "type": "object",
      "required": ["nodes"],
      "properties": {
        "nodes": { "type": "array", "items": { "$ref": "#/definitions/TemplateProjectPlanNode" } }
      },
      "additionalProperties": false
    },
    "TemplateProjectPlanNode": {
      "type": "object",
      "required": ["id", "title", "type"],
      "properties": {
        "id": { "type": "number" },
        "title": { "type": "string" },
        "type": { "$ref": "plan-node-types.json#" },
        "aiUserInstructions": { "type": "array", "items": { "type": "string" } },
        "nodeTypeSettings": { "type": "object" },
        "content": { "type": "array", "items": { "type": "string" } },
        "children": { "type": "array", "items": { "$ref": "#/definitions/TemplateProjectPlanNode" } },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/definitions/TemplateProjectPlanNodeInput" }
        }
      },
      "additionalProperties": false
    },
    "TemplateProjectPlanNodeInput": {
      "type": "object",
      "required": ["sourceNodeId", "type"],
      "properties": {
        "sourceNodeId": { "type": "number" },
        "type": { "$ref": "plan-edge-types.json#" }
      },
      "additionalProperties": false
    }
  }
}
