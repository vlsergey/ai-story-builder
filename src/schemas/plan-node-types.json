        "lore",
        "merge",
        "split",
        "fix-problems",
        "for-each-input",
        "for-each-output",
        "for-each-prev-outputs"
      ]
    },
    "PlanEdgeType": {
      "type": "string",
      "enum": ["text", "textArray"]
    }
  }
}
