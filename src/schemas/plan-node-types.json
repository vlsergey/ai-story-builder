{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanNodeType",
  "anyOf": [{ "$ref": "#/definitions/PlanContainerNodeType" }, { "$ref": "#/definitions/PlanNonContainerNodeType" }],
  "definitions": {
    "PlanContainerNodeType": {
      "type": "string",
      "enum": ["for-each"]
    },
    "PlanNonContainerNodeType": {
      "type": "string",
      "enum": [
