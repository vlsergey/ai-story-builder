  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.1",
    "pkg": "^5.8.0"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2",
    "multer": "^1.4.5",
    "open": "^8.4.0"
  }
