{
  "name": "ai-story-builder",
  "version": "0.1.0",
  "description": "AI-powered story building tool",
  "author": "Sergey Vladimirov",
  "private": true,
  "type": "module",
  "main": "dist/backend/main.js",
  "workspaces": [
    "src/frontend",
    "src/backend"
  ],
  "scripts": {
    "postinstall": "electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3",
    "generate-code": "tsx scripts/js-schemas-to-ts.ts && biome format --write src/shared",
    "dev": "electron-rebuild -f -w better-sqlite3 && concurrently \"npm run dev --workspace=src/backend\" \"npm run dev --workspace=src/frontend\" \"wait-on dist/backend/main.js dist/preload/preload.cjs tcp:localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "build": "npm run build:backend && npm run build:frontend",
    "build:frontend": "npm run build --workspace=src/frontend",
    "build:backend": "npm run build --workspace=src/backend",
    "test": "npm rebuild better-sqlite3 && npm run test --workspace=src/backend && npm run test --workspace=src/frontend",
    "typecheck": "npm run typecheck --workspace=src/backend && tsc -p src/frontend/tsconfig.json",
    "package": "npm run build && electron-builder --publish never",
    "generate-schema": "npm rebuild better-sqlite3 && npm run build:backend && tsx scripts/generate-schema.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --assist-enabled=true --formatter-enabled=true --write .",
    "lint:fix:unsafe": "biome check --assist-enabled=true --formatter-enabled=true --write --unsafe .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "eslint": "eslint",
    "precommit": "npm run typecheck && npm run format:fix && npm run lint:fix && npm run eslint && npm run test"
  },
  "dependencies": {
    "@trpc/server": "^10.45.4",
    "best-effort-json-parser": "^1.4.0",
    "electron-trpc": "^0.7.1",
    "json-schema-to-ts": "^3.1.1",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/mustache": "^4.2.6",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "mustache": "^4.2.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.example.ai-story-builder",
    "productName": "AI Story Builder",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "src/backend/resources/resources",
        "to": "resources",
        "filter": "**/*"
      }
    ],
    "files": [
      "src/backend/icons/*",
      "dist/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "npmRebuild": true,
    "win": {
      "icon": "src/backend/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "src/backend/icons/256x256.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "src/backend/icons/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  }
}
