{
  "name": "ai-story-builder",
  "version": "0.1.0",
  "description": "AI-powered story building tool",
  "author": "Sergey Vladimirov",
  "private": true,
  "main": "src/electron/main.js",
  "workspaces": [
    "src/frontend",
    "src/backend"
  ],
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dev": "concurrently \"npm run dev --workspace=src/backend\" \"npm run dev --workspace=src/frontend\" \"wait-on dist/backend/server.js tcp:localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "build": "npm run build --workspace=src/frontend",
    "build:backend": "npm run build --workspace=src/backend",
    "test": "npm run test --workspace=src/backend && npm run test --workspace=src/frontend",
    "typecheck": "npm run typecheck --workspace=src/backend && tsc -p src/frontend/tsconfig.json",
    "package": "npm run build:backend && npm run build && electron-builder --publish never"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-rebuild": "^3.2.9",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.example.ai-story-builder",
    "productName": "AI Story Builder",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/*.node"
    ],
    "files": [
      "src/electron/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }]
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }]
    }
  }
}
